<Window x:Class="SIBDAT25_2S_CCD__WPF_Softwareudvikling_og_arkitektur.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SIBDAT25_2S_CCD__WPF_Softwareudvikling_og_arkitektur"
        mc:Ignorable="d"
        Title="Smart Home Manager" Height="420" Width="500"
        Background="White"
        Foreground="Black">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Smart Home Manager"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="Tænd" Width="100" Margin="0,0,8,0" Click="TurnOn_Click"/>
            <Button Content="Sluk" Width="100" Margin="0,0,8,0" Click="TurnOff_Click"/>
            <Button x:Name="MovieModeButton" Content="Filmtilstand: Fra" Width="140" Click="MovieMode_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock VerticalAlignment="Center" Text="Temperatur:" Margin="0,0,8,0"/>
            <TextBox x:Name="TemperatureInput" Width="80" Margin="0,0,8,0" VerticalContentAlignment="Center"/>
            <Button Content="Sæt" Width="80" Click="SetTemperature_Click"/>
            <TextBlock VerticalAlignment="Center" Text="Nuværende:" Margin="12,0,6,0"/>
            <TextBlock x:Name="CurrentTemperatureText" VerticalAlignment="Center" Text="-- °C" FontWeight="SemiBold"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="&#xE793;" FontFamily="Segoe MDL2 Assets" FontSize="24" x:Name="LightIcon" Foreground="Gray"/>
            <TextBlock Text=" Lys" VerticalAlignment="Center" Margin="4,0,16,0"/>
            <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="24" x:Name="MovieIcon" Foreground="Gray"/>
            <TextBlock Text=" Filmtilstand" VerticalAlignment="Center" Margin="4,0,0,0"/>
        </StackPanel>

        <ListBox x:Name="StatusList" Grid.Row="4" BorderBrush="Black" BorderThickness="1"/>
    </Grid>
</Window>
